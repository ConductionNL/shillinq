{
  "openapi": "3.0.0",
  "info": {
    "title": "Shillinq Register",
    "description": "Register containing all schemas for the Shillinq business administration suite.",
    "version": "0.1.0"
  },
  "x-openregister": {
    "type": "application",
    "app": "shillinq",
    "openregister": "^v0.2.10",
    "description": "Shillinq — complete open-source business administration suite for freelancers, sole proprietors, SMBs, and corporations."
  },
  "paths": {},
  "components": {
    "schemas": {
      "organization": {
        "slug": "organization",
        "icon": "DomainOutline",
        "version": "0.1.0",
        "title": "Organization",
        "description": "An organization entity representing a business or legal entity.",
        "x-schema-org": "schema:Organization",
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Legal name of the organization",
            "example": "Demo B.V."
          },
          "registrationNumber": {
            "type": "string",
            "description": "KvK (Chamber of Commerce) number",
            "example": "12345678"
          },
          "email": {
            "type": "string",
            "description": "Contact email address",
            "example": "info@example.nl"
          },
          "phone": {
            "type": "string",
            "description": "Contact phone number",
            "example": "+31 20 123 4567"
          },
          "website": {
            "type": "string",
            "description": "Organization website URL",
            "example": "https://example.nl"
          },
          "address": {
            "type": "string",
            "description": "Street name and number",
            "example": "Keizersgracht 100"
          },
          "city": {
            "type": "string",
            "description": "City name",
            "example": "Amsterdam"
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code",
            "example": "NL"
          }
        }
      },
      "appSettings": {
        "slug": "appSettings",
        "icon": "CogOutline",
        "version": "0.1.0",
        "title": "AppSettings",
        "description": "Application-wide or per-user configuration settings.",
        "x-schema-org": "custom",
        "type": "object",
        "required": [
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string",
            "description": "Setting identifier",
            "example": "fiscalYearStart"
          },
          "value": {
            "type": "string",
            "description": "Setting value, always stored as string",
            "example": "EUR"
          },
          "dataType": {
            "type": "string",
            "description": "Data type hint for the value",
            "enum": [
              "string",
              "boolean",
              "number",
              "json"
            ],
            "default": "string"
          },
          "category": {
            "type": "string",
            "description": "UI grouping category",
            "enum": [
              "appearance",
              "notifications",
              "integrations",
              "general"
            ]
          },
          "editable": {
            "type": "boolean",
            "description": "Whether the setting can be changed via the UI",
            "default": true
          },
          "userId": {
            "type": "string",
            "description": "User ID for per-user preference; null for app-wide setting"
          }
        }
      },
      "dashboard": {
        "slug": "dashboard",
        "icon": "ViewDashboardOutline",
        "version": "0.1.0",
        "title": "Dashboard",
        "description": "Dashboard layout configuration.",
        "x-schema-org": "schema:Thing",
        "type": "object",
        "required": [
          "title",
          "layoutType"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Dashboard title",
            "example": "Default Dashboard"
          },
          "description": {
            "type": "string",
            "description": "Dashboard description"
          },
          "layoutType": {
            "type": "string",
            "description": "Layout rendering mode",
            "enum": [
              "grid",
              "flexbox",
              "custom"
            ],
            "default": "grid"
          },
          "isDefault": {
            "type": "boolean",
            "description": "Whether this is the default dashboard for the user",
            "default": false
          },
          "theme": {
            "type": "string",
            "description": "NL Design System theme variant"
          },
          "userId": {
            "type": "string",
            "description": "Owner user ID; null for shared dashboards"
          }
        }
      },
      "dataJob": {
        "slug": "dataJob",
        "icon": "DatabaseImportOutline",
        "version": "0.1.0",
        "title": "DataJob",
        "description": "Tracks bulk data import/export jobs.",
        "x-schema-org": "schema:Thing",
        "type": "object",
        "required": [
          "fileName",
          "entityType",
          "status"
        ],
        "properties": {
          "fileName": {
            "type": "string",
            "description": "Uploaded file name",
            "example": "organizations.csv"
          },
          "entityType": {
            "type": "string",
            "description": "Target schema for the import",
            "example": "organization"
          },
          "status": {
            "type": "string",
            "description": "Current job status",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "default": "pending"
          },
          "totalRecords": {
            "type": "integer",
            "description": "Total rows in the source file",
            "default": 0
          },
          "processedRecords": {
            "type": "integer",
            "description": "Successfully imported records",
            "default": 0
          },
          "failedRecords": {
            "type": "integer",
            "description": "Rows that failed validation",
            "default": 0
          },
          "errorLog": {
            "type": "string",
            "description": "JSONL of per-row errors"
          },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when processing started"
          },
          "completedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when processing finished"
          },
          "userId": {
            "type": "string",
            "description": "User who initiated the import"
          }
        }
      }
    }
  }
}
